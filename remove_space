#include<iostream>
#include<string>
using namespace std;

int main() {
    string str;
    cout << "Enter a string: ";
    getline(cin, str);
    string result;
    for (char c : str) {
        if (c != ' ') { // Remove spaces
            result += c;
        }
    }
    cout << "String without spaces: " << result << endl;
    return 0;
}
